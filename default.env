# Copy this file to .env and customize it for your deployment.
ENV_VERSION=4

COMPOSE_FILE=ronin.yml:rpc-shared.yml
PROJECT_NAME=ronin

# Ronin is now an OP Stack network operated by Conduit. This setup runs
# Conduit's op-reth build plus op-node and restores the official reth snapshot.
NETWORK=ronin
EXPECTED_CHAIN_ID=0x7e4
DATADIR=./datadir
SNAPSHOT=https://storage.googleapis.com/conduit-networks-snapshots/ronin-mainnet-bfz9fadqzl/latest.tar
UPDATE_BEDROCK_BLOCK=true

RETH_DOCKER_TAG=v1.0.0-rc.1
OP_NODE_DOCKER_TAG=v1.16.5
EIGENDA_PROXY_VERSION=2.7.0

# Conduit's public sequencer URL is fine for bootstrap, but production RPCs
# should use an API-key URL from https://app.conduit.xyz/nodes to avoid 429s.
RETH_SEQUENCER_URL=https://rpc-ronin-mainnet-bfz9fadqzl.t.conduit.xyz
# Optional. Set this if you need pre-Bedrock historical RPC responses.
RETH_HISTORICAL_RPC=
OP_NODE_L1_ETH_RPC=https://eth-rpc.example.com
OP_NODE_L1_BEACON=https://eth-cl.example.com
OP_NODE_P2P_STATIC=/ip4/34.169.70.196/tcp/9222/p2p/16Uiu2HAkxJUuUQFe6eLwhT8pHYRFYTch1MoeuWDoEFKbdAZANbMk
OP_NODE_P2P_SYNC_ONLYREQTOSTATIC=true
OP_NODE_ALTDA_DA_SERVER=http://ronin-eigenda-proxy:3100

EIGENDA_PROXY_STORAGE_BACKENDS_TO_ENABLE=V2
EIGENDA_PROXY_STORAGE_DISPERSAL_BACKEND=V2
EIGENDA_PROXY_EIGENDA_V2_NETWORK=mainnet
EIGENDA_PROXY_EIGENDA_V2_CERT_VERIFIER_ROUTER_OR_IMMUTABLE_VERIFIER_ADDR=0x1be7258230250Bc6a4548F8D59d576a87D216C12
EIGENDA_PROXY_EIGENDA_V2_DISPERSER_RPC=disperser.eigenda.xyz:443

# External Docker network if using ext-network.yml
DOCKER_EXT_NETWORK=traefik_default

# Secure web proxy - to be used with traefik
DOMAIN=example.com
RPC_HOST=ronin
RPC_LB=ronin-lb
WS_HOST=roninws
WS_LB=roninws-lb

RPC_PORT=8545
WS_PORT=8546
OP_NODE_RPC_PORT=7545
OP_NODE_P2P_PORT=9222

# Set a GitHub tag here if you pin this repo outside normal git workflows.
SCRIPT_TAG=
